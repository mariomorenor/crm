<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="star_whatsapp.view_whatsapp_send_wizard_form" model="ir.ui.view">
            <field name="name">star.whatsapp.send.wizard.form</field>
            <field name="model">star_whatsapp.send.wizard</field>
            <field name="arch" type="xml">
                <form string="Enviar WhatsApp">

                    <group>
                        <field name="partner_id"/>
                        <field name="number"/>
                        <field name="template_id"/>
                        <field name="message"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>

                    <footer>
                        <!-- ESTE ES EL IMPORTANTE -->
                        <button name="action_send"
                                type="object"
                                string="Enviar"
                                class="btn btn-primary"/>

                        <button string="Cancelar"
                                special="cancel"
                                class="btn-secondary"/>
                    </footer>

                </form>
            </field>
        </record>
    </data>
</odoo>