<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="star_whatsapp.messages_form_view" model="ir.ui.view">
            <field name="name">Star Whatsapp: Mensajes Form View</field>
            <field name="model">star_whatsapp.messages</field>
            <field name="arch" type="xml">
                <form string="Messages">

                    <header>
                        <button name="send_message"
                                type="object"
                                string="Enviar"
                                class="btn-primary"
                                invisible="state != 'draft'"/>
                        <button name="action_set_draft"
                                type="object"
                                string="Borrador"
                                class="btn-secondary"
                                invisible="state != 'error'"/>
                        <button name="action_retry_and_send"
                                type="object"
                                string="Reintentar"
                                class="btn-secondary"
                                invisible="state != 'error'"/>
                        <field name="state" widget="statusbar"/>
                    </header>

                    <sheet >
                        <div class="oe_title">
                            <label for="partner_id"/>
                            <h1>
                                <field name="partner_id" placeholder="Buscar..."/>
                            </h1>
                        </div>

                        <group >
                            <group>
                                <field name="instance_id" required="1" readonly="state in ['sent', 'error']"
                                       options="{'no_create': True, 'no_create_edit': True}"/>

                                <field name="country_id"  readonly="state in ['sent', 'error']"
                                       options="{'no_create': True, 'no_create_edit': True}"/>

                                <field name="number" readonly="state in ['sent', 'error']"/>

                                <field name="number_formatted" readonly="1"/>

                                <field name="message" readonly="state in ['sent', 'error']" colspan="2"/>
                            </group>

                            <group >
                                <field name="file" filename="file_name" readonly="state in ['sent', 'error']"/>
                                <field name="file_name" invisible="1"/>
                                <field name="delay" invisible="1"/>
                            </group>
                        </group>

                        <group>
                            <field name="response" readonly="1"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="star_whatsapp.messages_tree_view" model="ir.ui.view">
            <field name="name">Star Whatsapp: Mensajes List View</field>
            <field name="model">star_whatsapp.messages</field>
            <field name="arch" type="xml">
                <list string="Messages">
                    <field name="number"/>
                    <field name="message"/>
                    <field name="file_name"/>
                </list>
            </field>
        </record>

        <record id="star_whatsapp.messages_search_view" model="ir.ui.view">
            <field name="name">Star Whatsapp: Mensajes Search View</field>
            <field name="model">star_whatsapp.messages</field>
            <field name="arch" type="xml">
                <search string="Messages">
                    <field name="number"/>
                </search>
            </field>
        </record>

        <record id="star_whatsapp.messages_act_window" model="ir.actions.act_window">
            <field name="name">Mensajes</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">star_whatsapp.messages</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    No hay mensajes
                </p>
            </field>
        </record>

        <menuitem name="Mensajes" id="star_whatsapp.messages_menu" parent="star_whatsapp.main_menu"
                  action="star_whatsapp.messages_act_window"/>

    </data>
</odoo>